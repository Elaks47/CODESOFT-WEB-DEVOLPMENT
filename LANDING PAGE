<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Landing Page</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

<!-- Header -->
<header>
    <h1>My Landing Page</h1>
    <nav>
        <a href="#">Home</a>
        <a href="#">Features</a>
        <a href="#">About</a>
        <a href="#">Contact</a>
    </nav>
</header>

<!-- Hero Section -->
<section class="hero">
    <h2>Welcome to My Website</h2>
    <p>Create beautiful websites with HTML & CSS</p>
    <button>Get Started</button>
</section>

<!-- Features Section -->
<section class="features">
    <div class="box">
        <h3>Fast</h3>
        <p>Quick loading and smooth performance.</p>
    </div>
    <div class="box">
        <h3>Responsive</h3>
        <p>Looks great on all devices.</p>
    </div>
    <div class="box">
        <h3>Easy</h3>
        <p>Simple and beginner-friendly design.</p>
    </div>
</section>

<!-- About Section -->
<section class="about">
    <h2>About Us</h2>
    <p>
        This is a simple landing page project using HTML and CSS.
        You can customize it based on your creativity.
    </p>
</section>

<!-- Contact Section -->
<section class="contact">
    <h2>Contact</h2>
    <p>Email: example@email.com</p>
</section>

<!-- Footer -->
<footer>
    <p>© 2026 Landing Page | All Rights Reserved</p>
</footer>

</body>
</html>


body {
    margin: 0;
    font-family: Arial, sans-serif;
}

/* Header */
header {
    background: #333;
    color: white;
    padding: 15px;
    text-align: center;
}

nav a {
    color: white;
    margin: 10px;
    text-decoration: none;
}

/* Hero Section */
.hero {
    background: linear-gradient(to right, #4facfe, #00f2fe);
    color: white;
    text-align: center;
    padding: 80px 20px;
}

button {
    padding: 10px 20px;
    border: none;
    background: white;
    color: black;
    cursor: pointer;
}

/* Features */
.features {
    display: flex;
    justify-content: space-around;
    padding: 40px;
}

.box {
    width: 30%;
    background: #f4f4f4;
    padding: 20px;
    text-align: center;
}

/* About */
.about {
    padding: 40px;
    text-align: center;
}

/* Contact */
.contact {
    padding: 40px;
    text-align: center;
}

/* Footer */
footer {
    background: #333;
    color: white;
    text-align: center;
    padding: 15px;
}
